# Copia este archivo a  .env  y rellena los valores.
#   cp .env.example .env

# Dominio público donde vivirá el sitio (por ejemplo, tu subdominio DuckDNS).
# Debe apuntar (DNS) a la IP de tu servidor.
DOMAIN=insumos.tudominio.duckdns.org

# Correo para los avisos del certificado HTTPS (Let's Encrypt).
EMAIL=tu-correo@ejemplo.com

# Clave para firmar los tokens de sesión. GENERA UNA PROPIA:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# Contraseña de administrador (para revisar y borrar centros).
# Si la defines aquí, será la única válida. Cámbiala.
ADMIN_PASSWORD=cambia-esta-contraseña

# Días de validez del token de un centro antes de pedir el código otra vez.
TOKEN_TTL_DAYS=30

# Solo si el front estuviera en OTRO dominio distinto al de la API.
# Déjalo vacío si sirves todo desde el mismo sitio (lo normal aquí).
# ALLOW_ORIGIN=
